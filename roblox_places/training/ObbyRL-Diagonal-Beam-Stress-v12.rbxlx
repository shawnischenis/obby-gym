          <string name="Source"><![CDATA[--!strict

return table.freeze({
	startPosition = Vector3.new(0, 4, 0),
	headingDegrees = 0,
	platformWidth = 12,
	platformLength = 14,
	platformHeight = 1,
	gapMin = 4,
	gapMax = 8,
	finishDepth = 4,
	killPlaneY = -25,
})
