{
  "name": "ObbyRL",
  "servePort": 34872,
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$path": "src/ReplicatedStorage"
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$path": "src/ServerScriptService"
    },
    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "StreamingEnabled": false,
        "Gravity": 196.2
      }
    }
  }
}
