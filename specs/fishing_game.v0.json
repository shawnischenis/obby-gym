{
  "$schema_version": "0.1",
  "meta": {
    "title": "Island Fishing",
    "genre": "casual_fishing",
    "source_prompt": "build me a game for fishing where the map spawn is on a small island with a dock, and its surrounded by water, you begin with a rod that you can click and if it hits the water after a few seconds you can begin reeling in a fish (there should exist different rarities and different fish sizes)"
  },
  "world": {
    "ambient": { "biome": "tropical", "time_of_day": "day", "sky": "clear" },
    "regions": [
      {
        "id": "ocean",
        "kind": "water_plane",
        "size": { "x": 600, "z": 600 },
        "y_level": 0,
        "color": [25, 100, 145]
      },
      {
        "id": "island",
        "kind": "terrain_island",
        "center": [0, 0, 0],
        "radius": 40,
        "peak_height": 6,
        "material": "Sand",
        "shore_material": "Sand"
      }
    ],
    "spawn": { "on": "island", "near": "center", "offset_y": 6 }
  },
  "structures": [
    {
      "id": "dock",
      "kind": "wooden_dock",
      "anchor": { "on": "island", "edge": "south", "extend_into": "ocean" },
      "size": { "length": 20, "width": 4, "deck_height": 1.5 },
      "posts": { "spacing": 4, "submerge_depth": 3 }
    }
  ],
  "entities": [
    {
      "id": "starter_rod",
      "kind": "tool",
      "display_name": "Fishing Rod",
      "asset_ref": { "strategy": "creator_store_first", "query": "fishing rod tool", "fallback": "procedural_rod" },
      "given_to_player_on_spawn": true,
      "mechanics_ref": "fishing_flow"
    }
  ],
  "mechanics": [
    {
      "id": "fishing_flow",
      "template": "click_to_cast_reel",
      "params": {
        "cast_range_studs": 40,
        "must_hit_tag": "water",
        "bite_delay_seconds_min": 2.0,
        "bite_delay_seconds_max": 6.0,
        "reel_window_seconds": 5.0,
        "miss_on_no_input": true
      }
    }
  ],
  "progression": {
    "fish_table": [
      { "name": "Anchovy",     "rarity": "common",    "weight": 60, "size_min": 0.4, "size_max": 0.9, "color": [180, 180, 170] },
      { "name": "Perch",       "rarity": "common",    "weight": 25, "size_min": 0.8, "size_max": 1.4, "color": [120, 150, 90] },
      { "name": "Bass",        "rarity": "uncommon",  "weight": 10, "size_min": 1.2, "size_max": 2.2, "color": [80, 110, 70] },
      { "name": "Swordfish",   "rarity": "rare",      "weight": 4,  "size_min": 2.5, "size_max": 4.0, "color": [60, 90, 130] },
      { "name": "Golden Tuna", "rarity": "legendary", "weight": 1,  "size_min": 3.0, "size_max": 5.0, "color": [220, 180, 60] }
    ],
    "rarity_colors": {
      "common":    [200, 200, 200],
      "uncommon":  [110, 220, 120],
      "rare":      [80, 140, 230],
      "legendary": [240, 190, 70]
    }
  },
  "verification_checks": [
    { "kind": "structural", "assert_exists": ["Workspace.Island", "Workspace.Dock", "Workspace.Ocean"] },
    { "kind": "structural", "assert_exists": ["StarterPack.Fishing Rod", "ServerScriptService.FishingServer"] },
    { "kind": "console", "assert_no_errors_after": "build" },
    { "kind": "runtime", "play_seconds": 3, "assert_no_errors_after": "play" }
  ]
}
